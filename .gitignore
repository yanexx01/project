```gitignore
# Python compiled files
*.pyc
__pycache__/

# Django migrations cache
**/migrations/__pycache__/

# Logs
*.log

# Environment variables
.env
.env.local
.env.*

# IDE
.vscode/
.idea/

# OS
.DS_Store
Thumbs.db

# Coverage reports
coverage/
htmlcov/
.coverage

# Temporary files
*.tmp
*.swp
*.swo

# Dependencies
.venv/
venv/
node_modules/
.mypy_cache/
.pytest_cache/
dist/
build/
target/
.gradle/

# DB
*.sqlite3

# Static files
media/
staticfiles/
```
